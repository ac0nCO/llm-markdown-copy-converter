{
  "manifest_version": 3,
  "name": "LLM Markdown Copy Converter",
  "version": "2.9.9",
  "description": "Convert LLM Markdown replies into Word-friendly rich text or clean chat text.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Markdown Copy Converter"
  },
  "permissions": [
    "clipboardWrite",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://poe.com/*",
    "https://chat.deepseek.com/*",
    "https://www.doubao.com/*",
    "https://kimi.moonshot.cn/*",
    "https://tongyi.aliyun.com/*",
    "https://yuanbao.tencent.com/*",
    "https://chatglm.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://kimi.moonshot.cn/*",
        "https://tongyi.aliyun.com/*",
        "https://yuanbao.tencent.com/*",
        "https://chatglm.cn/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
